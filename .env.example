# Codegen Bridge — environment variables
# Copy to .env and fill in your values:  cp .env.example .env

# Required: API key from https://codegen.com
CODEGEN_API_KEY=your-api-key-here

# Required: Organization ID (integer) from codegen.com dashboard
CODEGEN_ORG_ID=12345

# Optional: Allow dangerous tools (stop/ban) without interactive confirmation
# CODEGEN_ALLOW_DANGEROUS_TOOLS=true
